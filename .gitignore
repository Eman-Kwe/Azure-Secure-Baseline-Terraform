# Terraform state — contains resource details and secrets, never commit
*.tfstate
*.tfstate.*

# Downloaded providers/modules — regenerated by 'terraform init'
.terraform/

# Local values (subscription ID, IP, email) — .example file shows the shape
terraform.tfvars
*.auto.tfvars

# Plan files and crash logs can embed sensitive values
*.tfplan
crash.log

# Keys and OS noise
*.pem
azlab*
.DS_Store